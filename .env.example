# ===== Database (Supabase) =====
# Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" pooler URL (port 6543) for DATABASE_URL
# and the "Session"/direct URL (port 5432) for DIRECT_URL.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ===== Auth =====
# Generate with: npx auth secret   (or any long random string)
AUTH_SECRET="change-me-to-a-long-random-string"

# ===== Jobs (cron) =====
# Protects POST /api/v1/jobs/run — any long random string
JOBS_SECRET="change-me"

# ===== Email (Resend) =====
# Free at resend.com — powers password reset, quote emails, booking confirmations.
# NOTE: with the sandbox sender (onboarding@resend.dev) Resend only delivers to
# the email that owns the Resend account; verify a domain for real recipients.
RESEND_API_KEY="re_..."
EMAIL_FROM="AI Receptionist <onboarding@resend.dev>"

# ===== AI (Groq) =====
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# ===== App URL =====
# Public origin of the deployed app (no trailing slash), e.g. https://app.example.com
# Used to build the webhook/callback URLs shown on the Integrations page.
NEXT_PUBLIC_APP_URL=""

# ===== Semantic search (optional) =====
# Enables pgvector embeddings for the knowledge base (falls back to keyword
# search without it). Also usable as an alternative chat provider.
OPENAI_API_KEY=""

# ===== Vercel Cron (optional) =====
# Vercel injects this automatically for GET /api/v1/jobs/run when set in
# the project's env; JOBS_SECRET above still works for other schedulers.
CRON_SECRET=""

# ===== CORS (optional, for authenticated API endpoints) =====
# Comma-separated list of allowed origins for authenticated endpoints.
# Public widget endpoints always allow "*" (rate-limited).
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=""

# ===== Error Tracking (optional) =====
# Sentry.io DSNs for centralized error monitoring + alerts.
# Leave blank to log errors locally only.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ===== Stripe billing (optional until you charge customers) =====
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs from Stripe → Products. ENTERPRISE is sales-led (no price id).
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PROFESSIONAL_MONTHLY=""
STRIPE_PRICE_PROFESSIONAL_YEARLY=""
STRIPE_PRICE_BUSINESS_MONTHLY=""
STRIPE_PRICE_BUSINESS_YEARLY=""

# ===== Google Calendar sync (optional) =====
# OAuth app at console.cloud.google.com → Credentials.
# Authorized redirect URI: $NEXT_PUBLIC_APP_URL/api/v1/integrations/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# NOTE: WhatsApp, Facebook/Instagram Messenger, and Twilio credentials are
# NOT env vars — each business connects their own accounts on the
# Integrations page in the dashboard.
